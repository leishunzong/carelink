page {
  background: #f7f8fa;
  height: 100vh;
}

.settlement-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.steps-wrapper {
  background: white;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-content {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.step-panel {
  background: #f7f8fa;
  border-radius: 16rpx;
}

.panel-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #323233;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.gender-section {
  background: white;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-top: 12rpx;
}

.section-label {
  font-size: 28rpx;
  color: #323233;
  margin-bottom: 16rpx;
}

.required-star {
  color: #ee0a24;
  margin-left: 4rpx;
}

.upload-section {
  padding: 8rpx;
}

.upload-item {
  background: white;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.upload-label {
  font-size: 28rpx;
  color: #323233;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.upload-hint {
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
}

.location-info {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f0f9ff;
  border-radius: 8rpx;
  margin-top: 16rpx;
}

.location-text {
  font-size: 28rpx;
  color: #07c160;
  margin-left: 8rpx;
}

.footer-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  background: white;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}
