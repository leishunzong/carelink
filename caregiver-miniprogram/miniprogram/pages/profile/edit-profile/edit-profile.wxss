page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
  background: white;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #e5e7eb;
}

.avatar-placeholder {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 64rpx;
  font-weight: 600;
  color: white;
}

.camera-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: #3b82f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid white;
}

.avatar-tip {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 16rpx;
}

/* 审核状态栏 */
.verify-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  font-size: 26rpx;
  gap: 8rpx;
}

.verify-bar.verify-1 {
  background: #dcfce7;
  color: #16a34a;
}

.verify-bar.verify-0 {
  background: #fff7ed;
  color: #f97316;
}

.verify-bar.verify-2 {
  background: #fef2f2;
  color: #ef4444;
}

/* 表单区域 */
.form-section {
  margin-top: 24rpx;
  background: white;
  padding: 32rpx 0 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  padding: 0 32rpx 24rpx;
}

/* 提交按钮 */
.submit-section {
  padding: 40rpx 32rpx;
}
