<view class="change-password-container">
  <view class="form-card">
    <!-- 安全提示 -->
    <view class="tips">
      <van-icon name="shield-o" size="16px" color="#3b82f6" />
      <text>为了您的账户安全，请定期更换密码。密码需包含字母和数字，长度6-20位。</text>
    </view>

    <!-- 原密码 -->
    <view class="field-group">
      <view class="field-label"><text class="required">*</text> 原密码</view>
      <view class="field-row">
        <input
          class="field-input"
          type="{{ showOldPassword ? 'text' : 'password' }}"
          placeholder="请输入原密码"
          value="{{ oldPassword }}"
          bindinput="onOldPasswordChange"
        />
        <view class="eye-btn" bindtap="toggleOldPassword">
          <van-icon name="{{ showOldPassword ? 'eye-o' : 'closed-eye' }}" size="20px" color="#9ca3af" />
        </view>
      </view>
    </view>

    <!-- 新密码 -->
    <view class="field-group">
      <view class="field-label"><text class="required">*</text> 新密码</view>
      <view class="field-row">
        <input
          class="field-input"
          type="{{ showNewPassword ? 'text' : 'password' }}"
          placeholder="请输入新密码"
          value="{{ newPassword }}"
          bindinput="onNewPasswordChange"
        />
        <view class="eye-btn" bindtap="toggleNewPassword">
          <van-icon name="{{ showNewPassword ? 'eye-o' : 'closed-eye' }}" size="20px" color="#9ca3af" />
        </view>
      </view>
    </view>

    <!-- 确认密码 -->
    <view class="field-group">
      <view class="field-label"><text class="required">*</text> 确认密码</view>
      <view class="field-row">
        <input
          class="field-input"
          type="{{ showConfirmPassword ? 'text' : 'password' }}"
          placeholder="请再次输入新密码"
          value="{{ confirmPassword }}"
          bindinput="onConfirmPasswordChange"
        />
        <view class="eye-btn" bindtap="toggleConfirmPassword">
          <van-icon name="{{ showConfirmPassword ? 'eye-o' : 'closed-eye' }}" size="20px" color="#9ca3af" />
        </view>
      </view>
    </view>

    <!-- 密码规则提示 -->
    <view class="password-rules">
      <view class="rule-title">密码要求：</view>
      <view class="rule-item {{ passwordRules.length ? 'pass' : '' }}">
        <van-icon name="{{ passwordRules.length ? 'success' : 'circle' }}" size="14px" color="{{ passwordRules.length ? '#16a34a' : '#d1d5db' }}" />
        <text>长度为6-20个字符</text>
      </view>
      <view class="rule-item {{ passwordRules.hasLetter ? 'pass' : '' }}">
        <van-icon name="{{ passwordRules.hasLetter ? 'success' : 'circle' }}" size="14px" color="{{ passwordRules.hasLetter ? '#16a34a' : '#d1d5db' }}" />
        <text>至少包含一个字母</text>
      </view>
      <view class="rule-item {{ passwordRules.hasNumber ? 'pass' : '' }}">
        <van-icon name="{{ passwordRules.hasNumber ? 'success' : 'circle' }}" size="14px" color="{{ passwordRules.hasNumber ? '#16a34a' : '#d1d5db' }}" />
        <text>至少包含一个数字</text>
      </view>
    </view>

    <!-- 提交按钮 -->
    <van-button
      type="info"
      size="large"
      round
      loading="{{ submitting }}"
      loading-text="提交中..."
      bind:click="handleSubmit"
      custom-style="margin-top: 40px;"
    >
      确认修改
    </van-button>
  </view>
</view>
