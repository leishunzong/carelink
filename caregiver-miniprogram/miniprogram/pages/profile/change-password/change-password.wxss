page {
  background: #f5f5f5;
}

.change-password-container {
  min-height: 100vh;
  padding: 32rpx;
}

.form-card {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 安全提示 */
.tips {
  display: flex;
  align-items: flex-start;
  background: #eff6ff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid #dbeafe;
}

.tips text {
  margin-left: 12rpx;
  font-size: 26rpx;
  color: #3b82f6;
  line-height: 1.5;
  flex: 1;
}

/* 表单字段 */
.field-group {
  margin-bottom: 32rpx;
}

.field-label {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.required {
  color: #ef4444;
  margin-right: 4rpx;
}

.field-row {
  display: flex;
  align-items: center;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 88rpx;
  background: #f9fafb;
  transition: border-color 0.2s;
}

.field-row:focus-within {
  border-color: #3b82f6;
  background: white;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
  height: 100%;
}

.eye-btn {
  padding: 16rpx;
  margin-right: -16rpx;
}

/* 密码规则 */
.password-rules {
  margin-top: 8rpx;
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.rule-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 16rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.rule-item.pass {
  color: #16a34a;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-item text {
  margin-left: 10rpx;
}
