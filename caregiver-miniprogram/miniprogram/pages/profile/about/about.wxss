/* pages/profile/about/about.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  background: white;
  margin-bottom: 16rpx;
}

.app-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 26rpx;
  color: #999;
}

.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}
