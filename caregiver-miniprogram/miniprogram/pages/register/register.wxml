<view class="register-container">
  <!-- 注册卡片 -->
  <view class="register-card">
    <view class="card-header">
      <view class="title">护工注册</view>
      <view class="subtitle">欢迎加入护工平台</view>
    </view>
    
    <!-- 注册表单 -->
    <view class="register-form">
      <view class="form-item">
        <view class="label">用户名</view>
        <input 
          class="input" 
          type="text" 
          placeholder="请输入用户名"
          value="{{ username }}"
          bindinput="onUsernameChange"
        />
      </view>
      
      <view class="form-item">
        <view class="label">密码</view>
        <input 
          class="input" 
          type="{{ showPassword ? 'text' : 'password' }}" 
          placeholder="请输入密码"
          value="{{ password }}"
          bindinput="onPasswordChange"
        />
      </view>
      
      <view class="form-item">
        <view class="label">手机号</view>
        <input 
          class="input" 
          type="number" 
          placeholder="请输入手机号"
          maxlength="11"
          value="{{ phone }}"
          bindinput="onPhoneChange"
        />
      </view>
      
      <view class="form-item">
        <view class="label">姓名</view>
        <input 
          class="input" 
          type="text" 
          placeholder="请输入真实姓名"
          value="{{ name }}"
          bindinput="onNameChange"
        />
      </view>
      
      <view class="form-item">
        <view class="label">性别</view>
        <view class="radio-group">
          <view class="radio-item" bindtap="selectGender" data-gender="男">
            <view class="radio {{ gender === '男' ? 'checked' : '' }}">
              <view class="radio-dot" wx:if="{{ gender === '男' }}"></view>
            </view>
            <text class="radio-label">男</text>
          </view>
          <view class="radio-item" bindtap="selectGender" data-gender="女">
            <view class="radio {{ gender === '女' ? 'checked' : '' }}">
              <view class="radio-dot" wx:if="{{ gender === '女' }}"></view>
            </view>
            <text class="radio-label">女</text>
          </view>
        </view>
      </view>
      
      <button 
        class="register-btn {{ loading ? 'loading' : '' }}" 
        bindtap="handleRegister"
        disabled="{{ loading }}"
      >
        {{ loading ? '注册中...' : '注册' }}
      </button>
      
      <view class="footer-link">
        <text class="link-text" bindtap="goToLogin">已有账号？去登录</text>
      </view>
    </view>
  </view>
</view>
