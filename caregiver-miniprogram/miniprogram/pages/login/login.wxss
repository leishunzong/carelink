.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.login-card {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.2);
  padding: 64rpx;
}

.card-header {
  text-align: center;
  margin-bottom: 64rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6b7280;
}

.login-form {
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 48rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1f2937;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.input::placeholder {
  color: #9ca3af;
}

.password-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.password-input {
  padding-right: 120rpx !important;
}

.toggle-password {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 26rpx;
  color: #3b82f6;
  padding: 8rpx 12rpx;
  z-index: 1;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: #3b82f6;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  border-radius: 12rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn:active {
  background: #2563eb;
}

.login-btn.loading {
  background: #93c5fd;
}

.footer-link {
  text-align: center;
  margin-top: 48rpx;
}

.link-text {
  font-size: 26rpx;
  color: #3b82f6;
}
