<view class="container">
    <!-- 分类筛选 -->
    <scroll-view scroll-x class="category-scroll">
        <view class="category-list">
            <view
                wx:for="{{categories}}"
                wx:key="id"
                class="category-item {{activeCategory === item.id ? 'active' : ''}}"
                bindtap="onCategoryChange"
                data-id="{{item.id}}"
            >
                {{item.name}}
            </view>
        </view>
    </scroll-view>

    <!-- 技能列表 -->
    <view class="skill-list">
        <block wx:for="{{skillList}}" wx:key="id">
            <view class="skill-item">
                <view class="skill-info">
                    <view class="skill-header">
                        <view class="skill-name">{{item.skillName}}</view>
                        <van-tag
                            wx:if="{{item.auditStatus === 0}}"
                            type="warning"
                            size="medium"
                        >待审核</van-tag>
                        <van-tag
                            wx:elif="{{item.auditStatus === 1}}"
                            type="success"
                            size="medium"
                        >已通过</van-tag>
                        <van-tag
                            wx:elif="{{item.auditStatus === 2}}"
                            type="danger"
                            size="medium"
                        >已拒绝</van-tag>
                    </view>

                    <view class="skill-meta">
                        <text class="skill-type">
                            {{item.skillType === 1 ? '临床医疗护理' : item.skillType === 2 ? '基础生活照料' : item.skillType === 3 ? '康复训练与介护' : item.skillType === 4 ? '失智专项护理' : item.skillType === 5 ? '居家安全与应急' : '精神慰藉与社交'}}
                        </text>
                        <text class="skill-level">{{item.levelText}}</text>
                    </view>

                    <view wx:if="{{item.description}}" class="skill-desc">{{item.description}}</view>

                    <view wx:if="{{item.createTime}}" class="skill-time">
                        <text>申请时间：{{item.createTime}}</text>
                    </view>

                    <view wx:if="{{item.auditStatus === 2}}" class="skill-reject-tip">
                        <van-icon name="warning-o" size="12px" />
                        <text>审核未通过，可删除后重新申请</text>
                    </view>
                </view>

                <view class="skill-actions">
                    <van-button
                        size="small"
                        type="danger"
                        plain
                        bind:click="onDeleteSkill"
                        data-skill-id="{{item.skillId}}"
                        data-name="{{item.skillName}}"
                    >删除</van-button>
                </view>
            </view>
        </block>
    </view>

    <!-- 空状态 -->
    <van-empty
        wx:if="{{!loading && skillList.length === 0}}"
        description="暂无已申请的技能"
    >
        <van-button slot="bottom" type="info" size="small" round bind:click="goToApplySkill">
            去申请技能
        </van-button>
    </van-empty>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="load-more">
        <van-loading size="20px">加载中...</van-loading>
    </view>

    <!-- 底部申请入口 -->
    <view wx:if="{{!loading && skillList.length > 0}}" class="bottom-action">
        <van-button type="info" round block bind:click="goToApplySkill">
            申请更多技能
        </van-button>
    </view>
</view>
