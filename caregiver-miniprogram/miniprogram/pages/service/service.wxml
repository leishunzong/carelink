<view class="service-container">
  <!-- Header -->
  <view class="header">
    <view class="header-title">服务中心</view>
    <view class="header-subtitle">管理您的技能和服务包</view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 服务申请组 -->
    <view class="menu-section">
      <view class="section-title">服务申请</view>
      <view class="menu-card">
        <view class="menu-item" bindtap="goToSettlement">
          <view class="menu-icon purple">
            <image class="icon-img" src="https://zlisten-1323337406.cos.ap-beijing.myqcloud.com/images/55-%E5%85%A5%E9%A9%BB%E5%8A%9E%E7%90%86.png" mode="aspectFit" />
          </view>
          <text class="menu-label">入驻申请</text>
          <text class="arrow">›</text>
        </view>

        <view class="menu-item" bindtap="goToSkillList">
          <view class="menu-icon blue">
            <image class="icon-img" src="https://zlisten-1323337406.cos.ap-beijing.myqcloud.com/images/6_4%E8%81%8C%E5%9C%BA%E6%8A%80%E8%83%BD.png" mode="aspectFit" />
          </view>
          <text class="menu-label">申请技能</text>
          <text class="arrow">›</text>
        </view>

        <view class="menu-item" bindtap="goToServicePackageList">
          <view class="menu-icon green">
            <image class="icon-img" src="https://zlisten-1323337406.cos.ap-beijing.myqcloud.com/images/%E6%9C%8D%E5%8A%A1%E5%8C%85%E7%AE%A1%E7%90%86.png" mode="aspectFit" />
          </view>
          <text class="menu-label">开通服务包</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 服务管理组 -->
    <view class="menu-section">
      <view class="section-title">服务管理</view>
      <view class="menu-card">
        <view class="menu-item" bindtap="goToSkillManagement">
          <view class="menu-icon orange">
            <image class="icon-img" src="https://zlisten-1323337406.cos.ap-beijing.myqcloud.com/images/%E6%8A%80%E8%83%BD%E7%AE%A1%E7%90%86.png" mode="aspectFit" />
          </view>
          <text class="menu-label">技能管理</text>
          <text class="arrow">›</text>
        </view>

        <view class="menu-item" bindtap="goToServicePackageManagement">
          <view class="menu-icon cyan">
            <image class="icon-img" src="https://zlisten-1323337406.cos.ap-beijing.myqcloud.com/images/%E6%9C%8D%E5%8A%A1%E5%8C%85%E7%AE%A1%E7%90%86%20%281%29.png" mode="aspectFit" />
          </view>
          <text class="menu-label">服务包管理</text>
          <text class="arrow">›</text>
        </view>

        <view class="menu-item" bindtap="goToReviewManagement">
          <view class="menu-icon yellow">
            <image class="icon-img" src="https://zlisten-1323337406.cos.ap-beijing.myqcloud.com/images/%E8%AF%84%E4%BB%B7%E7%AE%A1%E7%90%86.png" mode="aspectFit" />
          </view>
          <text class="menu-label">评价管理</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
