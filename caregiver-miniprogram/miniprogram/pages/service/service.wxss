page {
  background: #f3f4f6;
}

.service-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* Header */
.header {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  padding: 48rpx 32rpx 64rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 内容区域 */
.content {
  padding: 48rpx 32rpx;
}

/* 菜单分组 */
.menu-section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
  margin-bottom: 24rpx;
  padding: 0 16rpx;
}

/* 菜单卡片 */
.menu-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 菜单项 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f9fafb;
}

/* 菜单图标 */
.menu-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
}

.menu-icon.blue {
  background: #eff6ff;
}

.menu-icon.green {
  background: #f0fdf4;
}

.menu-icon.purple {
  background: #faf5ff;
}

.menu-icon.orange {
  background: #fff7ed;
}

.menu-icon.cyan {
  background: #ecfeff;
}

.menu-icon.yellow {
  background: #fefce8;
}

.icon-img {
  width: 52rpx;
  height: 52rpx;
}

/* 菜单标签 */
.menu-label {
  flex: 1;
  font-size: 32rpx;
  font-weight: 500;
  color: #1f2937;
}

/* 箭头 */
.arrow {
  font-size: 56rpx;
  font-weight: 300;
  color: #9ca3af;
}
