.container {
    min-height: 100vh;
    background-color: #f5f5f5;
    padding-bottom: 120rpx;
}

/* 分类筛选 */
.category-scroll {
    white-space: nowrap;
    background: white;
    padding: 16rpx 0;
}

.category-list {
    display: inline-flex;
    padding: 0 24rpx;
    gap: 16rpx;
}

.category-item {
    display: inline-block;
    padding: 12rpx 28rpx;
    border-radius: 32rpx;
    font-size: 26rpx;
    color: #666;
    background: #f5f5f5;
    white-space: nowrap;
}

.category-item.active {
    color: white;
    background: #1989fa;
}

/* 服务包列表 */
.package-list {
    padding: 24rpx 32rpx;
}

.package-item {
    background: white;
    border-radius: 16rpx;
    overflow: hidden;
    margin-bottom: 24rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.package-cover {
    width: 100%;
    height: 280rpx;
}

.package-body {
    padding: 24rpx 32rpx;
}

.package-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16rpx;
}

.package-name {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    flex: 1;
    margin-right: 16rpx;
}

.package-desc {
    font-size: 28rpx;
    color: #666;
    line-height: 1.6;
    margin-bottom: 16rpx;
}

.package-time {
    font-size: 24rpx;
    color: #999;
    margin-bottom: 16rpx;
}

.package-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* 空状态 */
van-empty {
    margin-top: 200rpx;
}

/* 加载状态 */
.load-more {
    display: flex;
    justify-content: center;
    padding: 40rpx 0;
}

/* 底部操作 */
.bottom-action {
    padding: 24rpx 32rpx;
}
