<view class="container">
    <!-- 分类筛选 -->
    <scroll-view scroll-x class="category-scroll">
        <view class="category-list">
            <view
                wx:for="{{categories}}"
                wx:key="id"
                class="category-item {{activeCategory === item.id ? 'active' : ''}}"
                bindtap="onCategoryChange"
                data-id="{{item.id}}"
            >
                {{item.name}}
            </view>
        </view>
    </scroll-view>

    <!-- 服务包列表 -->
    <view class="package-list">
        <block wx:for="{{packageList}}" wx:key="id">
            <view class="package-item">
                <!-- 封面图 -->
                <image
                    wx:if="{{item.coverImage}}"
                    class="package-cover"
                    src="{{item.coverImage}}"
                    mode="aspectFill"
                />

                <view class="package-body">
                    <view class="package-header">
                        <text class="package-name">{{item.name}}</text>
                        <van-tag type="primary" size="medium">{{item.categoryText}}</van-tag>
                    </view>

                    <view wx:if="{{item.description}}" class="package-desc">{{item.description}}</view>

                    <view wx:if="{{item.bindTime}}" class="package-time">
                        <text>开通时间：{{item.bindTime}}</text>
                    </view>

                    <view class="package-footer">
                        <van-tag type="success" size="medium">已开通</van-tag>
                        <van-button
                            size="small"
                            type="danger"
                            plain
                            bind:click="handleCancelPackage"
                            data-id="{{item.id}}"
                            data-name="{{item.name}}"
                        >取消开通</van-button>
                    </view>
                </view>
            </view>
        </block>
    </view>

    <!-- 空状态 -->
    <van-empty
        wx:if="{{!loading && packageList.length === 0}}"
        description="暂无已开通的服务包"
    >
        <van-button slot="bottom" type="info" size="small" round bind:click="goToOpenPackage">
            去开通服务包
        </van-button>
    </van-empty>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="load-more">
        <van-loading size="20px">加载中...</van-loading>
    </view>

    <!-- 底部开通入口 -->
    <view wx:if="{{!loading && packageList.length > 0}}" class="bottom-action">
        <van-button type="info" round block bind:click="goToOpenPackage">
            开通更多服务包
        </van-button>
    </view>
</view>
