page {
  background: #f3f4f6;
  height: 100vh;
}

.package-list-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 分类滚动 */
.category-scroll {
  background: white;
  white-space: nowrap;
  border-bottom: 1rpx solid #e5e7eb;
  flex-shrink: 0;
}

.category-list {
  display: inline-flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #f3f4f6;
  white-space: nowrap;
}

.category-item.active {
  background: #3b82f6;
  color: white;
}

/* 服务包列表 */
.package-scroll {
  flex: 1;
  padding: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 服务包卡片 */
.package-card {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.package-cover {
  width: 100%;
  height: 280rpx;
}

.package-cover-placeholder {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #eff6ff, #dbeafe);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
}

.package-content {
  padding: 24rpx;
}

.package-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.package-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.category-badge {
  font-size: 22rpx;
  color: #3b82f6;
  background: #eff6ff;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-left: 16rpx;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
  margin-left: 16rpx;
  white-space: nowrap;
}

.status-tag.opened {
  background: #dcfce7;
  color: #16a34a;
}

.price-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.price-tag {
  font-size: 28rpx;
  font-weight: 600;
  color: #f97316;
}

.package-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.package-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sales-text {
  font-size: 24rpx;
  color: #9ca3af;
}

.open-btn {
  padding: 12rpx 32rpx;
  background: #3b82f6;
  color: white;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.open-btn:active {
  background: #2563eb;
}

.cancel-btn {
  padding: 12rpx 32rpx;
  background: white;
  color: #dc2626;
  border: 1rpx solid #dc2626;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.cancel-btn:active {
  background: #fef2f2;
}

.loading-tip {
  text-align: center;
  padding: 32rpx;
}

.no-more-tip {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9ca3af;
}
