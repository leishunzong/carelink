/* pages/service/evaluation-list/evaluation-list.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 评分概览 */
.rating-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.summary-left {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rating-score {
  font-size: 80rpx;
  font-weight: bold;
  color: #ff9800;
  line-height: 1;
  margin-bottom: 12rpx;
}

.rating-count {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.summary-right {
  display: flex;
  align-items: center;
}

.good-rate {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rate-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
}

.rate-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 筛选栏 */
.filter-bar {
  background: white;
  margin-bottom: 16rpx;
}

/* 评价列表 */
.evaluation-list {
  padding: 0 32rpx;
}

.evaluation-item {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.evaluation-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.user-info {
  display: flex;
  gap: 16rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.user-detail {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.eval-time {
  font-size: 24rpx;
  color: #999;
}

.evaluation-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

/* 评价标签 */
.evaluation-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

/* 订单信息 */
.order-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.order-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.order-item van-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

/* 空状态 */
van-empty {
  margin-top: 200rpx;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}
