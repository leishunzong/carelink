page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.loading-container,
.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
}

/* 状态卡片 */
.status-card {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx;
}

.status-info {
  flex: 1;
  margin-left: 24rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  color: #6b7280;
}

.order-type-tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
  color: white;
}

.order-type-tag.system {
  background: #3b82f6;
}

.order-type-tag.direct {
  background: #10b981;
}

/* 通用 section */
.section {
  background: white;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  font-size: 28rpx;
}

.info-row .label {
  color: #6b7280;
  flex-shrink: 0;
  width: 160rpx;
}

.info-row .value {
  flex: 1;
  text-align: right;
  color: #1f2937;
  word-break: break-all;
}

.info-row .value.link {
  color: #3b82f6;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

/* 服务包卡片 */
.package-card {
  background: #eff6ff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.package-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.package-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.package-type-tag {
  font-size: 22rpx;
  background: #dbeafe;
  color: #2563eb;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.package-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.package-price {
  font-size: 28rpx;
  color: #f97316;
  font-weight: 500;
}

.package-total {
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 700;
}

/* 地址卡片 */
.address-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f9fafb;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.address-text {
  font-size: 28rpx;
  color: #374151;
  flex: 1;
  line-height: 1.5;
}

.time-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-text {
  font-size: 26rpx;
  color: #f97316;
  font-weight: 500;
}

/* 匹配要求 */
.requirement-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.req-item {
  display: flex;
  justify-content: space-between;
  background: #f9fafb;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.req-label {
  color: #6b7280;
}

.req-value {
  color: #1f2937;
  font-weight: 500;
}

/* 备注 */
.remark-card {
  background: #fffbeb;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #92400e;
  line-height: 1.6;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  border-top: 1rpx solid #f3f4f6;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}
