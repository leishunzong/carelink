<view class="page">
  <view class="list" wx:if="{{list.length > 0}}">
    <view class="card" wx:for="{{list}}" wx:key="id" bindtap="onCardTap" data-item="{{item}}">
      <view class="delete-btn" catchtap="onDelete" data-id="{{item.id}}" wx:if="{{!isSelectMode}}">删除</view>
      <view class="tag default" wx:if="{{item.isDefault}}">默认地址</view>
      <view class="region"><image class="loc-icon" src="https://zlisten-1323337406.cos.ap-beijing.myqcloud.com/images/%E5%AE%9A%E4%BD%8D-%E4%BD%8D%E7%BD%AE.png" mode="aspectFit"></image> {{item.address || item.full}}</view>
      <view class="detail" wx:if="{{item.doorNumber}}">{{item.doorNumber}}</view>
    </view>
  </view>
  <view class="empty" wx:else>
    <image class="empty-icon" src="https://zlisten-1323337406.cos.ap-beijing.myqcloud.com/images/%E5%AE%9A%E4%BD%8D-%E4%BD%8D%E7%BD%AE.png" mode="aspectFit"></image>
    <text class="empty-text">暂无服务地址</text>
    <button class="btn-primary add-btn" bindtap="goAdd">添加地址</button>
  </view>
  <view class="bottom-bar" wx:if="{{!isSelectMode && list.length > 0}}">
    <button class="btn-primary full" bindtap="goAdd">+ 添加新地址</button>
  </view>
</view>
