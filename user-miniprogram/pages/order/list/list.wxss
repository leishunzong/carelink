.page {
  min-height: 100vh;
  background: #f9fafb;
  display: flex;
  flex-direction: column;
}

.filter-row {
  background: #fff;
  white-space: nowrap;
  border-bottom: 1rpx solid #e5e7eb;
}

.filter-row.status-row {
  border-bottom: 1rpx solid #e5e7eb;
}

.filter-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
}

.filter-tab {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #6b7280;
  border-radius: 40rpx;
  background: #f3f4f6;
}

.filter-tab.active {
  background: #3B82F6;
  color: #fff;
  font-weight: 500;
}

.list {
  flex: 1;
  padding: 24rpx 32rpx;
  height: 0;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.head-left {
  flex: 1;
  min-width: 0;
}

.pkg-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.order-no {
  font-size: 24rpx;
  color: #9ca3af;
}

.status {
  font-size: 26rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-1 { color: #ef4444; }
.status-2, .status-3 { color: #3B82F6; }
.status-4 { color: #22c55e; }
.status-5 { color: #8b5cf6; }
.status-6, .status-7, .status-8 { color: #6b7280; }

.card-body {
  padding: 20rpx 32rpx;
}

.body-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.body-row:last-child {
  margin-bottom: 0;
}

.body-label {
  color: #9ca3af;
  flex-shrink: 0;
}

.body-value {
  flex: 1;
  min-width: 0;
}

.body-row-addr .body-value.clamp {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  border-top: 1rpx solid #f3f4f6;
}

.foot-left {
  min-width: 0;
  flex: 1;
  overflow: hidden;
}

.foot-left .foot-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #ef4444;
  margin-left: 16rpx;
}

.foot-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  min-width: 0;
  justify-content: flex-end;
}

.btn-outline,
.btn-primary-sm {
  padding: 0 10rpx;
  font-size: 20rpx;
  border-radius: 18rpx;
  height: 44rpx;
  line-height: 44rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.btn-outline {
  border: 2rpx solid #3B82F6;
  color: #3B82F6;
  background: transparent;
}

.btn-primary-sm {
  background: #3B82F6;
  color: #fff;
  border: none;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.btn-primary-sm.btn-disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.loading-tip, .no-more {
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #9ca3af;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-box {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  z-index: 101;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
  text-align: center;
  border: none;
}

.modal-btn.ghost {
  background: #f3f4f6;
  color: #6b7280;
}

.modal-btn.danger {
  background: #ef4444;
  color: #fff;
}

.modal-btn.primary {
  background: #3B82F6;
  color: #fff;
}
