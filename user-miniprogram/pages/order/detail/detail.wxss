.page {
  min-height: 100vh;
  padding-bottom: 180rpx;
  background: #f9fafb;
}

.status-section {
  background: #fff;
  padding: 48rpx 32rpx;
  text-align: center;
  border-bottom: 1rpx solid #f3f4f6;
}

.status-icon {
  display: block;
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 16rpx;
}

.status-text {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.status-desc {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
}

.block {
  background: #fff;
  margin: 24rpx 32rpx;
  border-radius: 20rpx;
  padding: 32rpx;
}

.block-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 28rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #6b7280;
  flex-shrink: 0;
  width: 200rpx;
}

.info-value {
  flex: 1;
  color: #111827;
  text-align: right;
}

.info-value.amount {
  font-weight: 700;
  color: #ef4444;
  font-size: 34rpx;
}

.total-row {
  padding-top: 20rpx;
  margin-top: 8rpx;
  border-top: 1rpx solid #f3f4f6;
}

.info-desc {
  padding: 16rpx 0;
  font-size: 28rpx;
}

.info-desc .info-label {
  display: block;
  margin-bottom: 8rpx;
}

.info-desc .info-value {
  text-align: left;
  display: block;
}

.caregiver-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 0;
}

.caregiver-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #e5e7eb;
  flex-shrink: 0;
}

.caregiver-info {
  flex: 1;
  min-width: 0;
}

.caregiver-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.caregiver-phone {
  font-size: 26rpx;
  color: #6b7280;
}

.caregiver-btn {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  border: 2rpx solid #3B82F6;
  color: #3B82F6;
  border-radius: 32rpx;
  flex-shrink: 0;
}

.addr-row {
  font-size: 28rpx;
  color: #111827;
  line-height: 1.5;
  display: flex;
  align-items: center;
}
.loc-icon {
  width: 32rpx;
  height: 32rpx;
  min-width: 32rpx;
  min-height: 32rpx;
  max-width: 32rpx;
  max-height: 32rpx;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  display: flex;
  justify-content: center;
  gap: 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}

.bottom-bar .btn-primary,
.bottom-bar .btn-ghost {
  flex: 1;
  max-width: 320rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
}

.bottom-bar .btn-primary {
  background: #3B82F6 !important;
  color: #fff !important;
  border: none;
}

.bottom-bar .btn-primary.disabled {
  background: #9ca3af !important;
  color: #fff !important;
}

.bottom-bar .btn-secondary {
  background: #f3f4f6 !important;
  color: #6b7280 !important;
  border: 1rpx solid #e5e7eb !important;
}

.bottom-bar .btn-secondary.disabled {
  background: #f9fafb !important;
  color: #9ca3af !important;
  border: 1rpx solid #e5e7eb !important;
}

.bottom-bar .btn-ghost {
  background: transparent;
  color: #6b7280;
  border: 2rpx solid #d1d5db;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-box {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  z-index: 101;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
  text-align: center;
}

.modal-btn.ghost {
  background: #f3f4f6;
  color: #6b7280;
  border: none;
}

.modal-btn.danger {
  background: #ef4444;
  color: #fff;
  border: none;
}

.modal-btn.primary {
  background: #3B82F6;
  color: #fff;
  border: none;
}
