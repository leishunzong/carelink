.page {
  min-height: 100vh;
  padding-bottom: 220rpx;
  background: #f5f5f5;
}

.block {
  background: #fff;
  margin: 24rpx 32rpx;
  border-radius: 20rpx;
  padding: 0 32rpx 24rpx;
  overflow: hidden;
}

.block-title {
  display: block;
  padding: 28rpx 0 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.caregiver-block {
  padding: 24rpx 32rpx;
}

.caregiver-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.caregiver-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}

.caregiver-info {
  flex: 1;
  min-width: 0;
}

.caregiver-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.caregiver-tip {
  font-size: 26rpx;
  color: #666;
}

.method-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.method-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
}

.method-item.active {
  border-color: #3B82F6;
  background: #eff6ff;
}

.method-left {
  flex: 1;
  min-width: 0;
}

.method-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.method-desc {
  font-size: 24rpx;
  color: #999;
}

.method-badge {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.method-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #3B82F6;
  flex-shrink: 0;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.row-label {
  font-size: 28rpx;
  color: #333;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  text-align: center;
  line-height: 52rpx;
  font-size: 32rpx;
  color: #666;
}

.stepper-num {
  min-width: 48rpx;
  text-align: center;
  font-size: 28rpx;
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.row-arrow:last-child {
  border-bottom: none;
}

.row-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.row-icon {
  font-size: 36rpx;
}

.row-value {
  font-size: 28rpx;
  color: #333;
}

.row-value.sub {
  display: block;
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #666;
}

.row-value.placeholder {
  color: #3B82F6;
}

/* 信息卡片样式 */
.info-card {
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.info-card:active {
  background: #f1f5f9;
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.info-icon-img {
  width: 32rpx;
  height: 32rpx;
  min-width: 32rpx;
  min-height: 32rpx;
  max-width: 32rpx;
  max-height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.info-title {
  flex: 1;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.info-action {
  font-size: 24rpx;
  color: #3b82f6;
}

.info-content {
  padding-left: 40rpx;
}

.info-text {
  font-size: 28rpx;
  color: #1e293b;
  line-height: 1.5;
}

.info-text.placeholder {
  color: #94a3b8;
}

.row-right {
  font-size: 26rpx;
  color: #3B82F6;
  flex-shrink: 0;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

.row-input {
  padding: 16rpx 0;
}

.input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}

.terms-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.terms-text {
  font-size: 26rpx;
  color: #666;
}

.bottom-inner {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.total-wrap {
  flex: 1;
}

.total-label {
  font-size: 24rpx;
  color: #999;
}

.total-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #3B82F6;
}

.submit {
  padding: 0 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #3B82F6 !important;
  color: #fff !important;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
}
