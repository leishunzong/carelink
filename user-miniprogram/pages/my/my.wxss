.page {
  min-height: 100vh;
  background: #f9fafb;
}

/* Header 全宽渐变 */
.header {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #3B82F6 0%, #2563eb 100%);
  padding: 96rpx 32rpx 64rpx;
}
.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
}
.circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}
.circle-1 { width: 512rpx; height: 512rpx; top: -128rpx; right: -128rpx; }
.circle-2 { width: 384rpx; height: 384rpx; bottom: -96rpx; left: -96rpx; }

.user-row {
  position: relative;
  display: flex;
  align-items: center;
  z-index: 1;
}
.avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #fff;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar { width: 100%; height: 100%; }
.avatar-placeholder { font-size: 80rpx; }
.info {
  flex: 1;
  margin-left: 32rpx;
  min-width: 0;
}
.nickname {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}
.phone {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}
.login-tip {
  flex: 1;
  margin-left: 32rpx;
  font-size: 32rpx;
  color: rgba(255,255,255,0.95);
}
.header-arrow {
  font-size: 48rpx;
  color: rgba(255,255,255,0.8);
}

/* Menu */
.menu-section { padding: 32rpx; }
.menu-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.menu-icon.blue { background: #eff6ff; }
.menu-icon.orange { background: #fff7ed; }
.menu-icon.green { background: #ecfdf5; }
.menu-icon.purple { background: #f5f3ff; }
.menu-icon.red { background: #fef2f2; }
.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
  min-width: 40rpx;
  min-height: 40rpx;
  max-width: 40rpx;
  max-height: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #111827;
}
.menu-arrow {
  font-size: 36rpx;
  color: #d1d5db;
}
.menu-item:active { background: #f9fafb; }

/* Logout */
.logout-section { padding: 0 32rpx 32rpx; }
.logout-btn {
  width: 100%;
  background: #fff;
  color: #ef4444;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.logout-btn:active { background: #fef2f2; }
