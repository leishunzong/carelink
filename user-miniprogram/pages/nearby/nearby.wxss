.page {
  min-height: 100vh;
  background: #f9fafb;
  padding: 32rpx;
}

.card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.body {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.distance {
  background: #3B82F6;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.row {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.star { margin-right: 16rpx; }

.tags {
  margin-bottom: 8rpx;
}

.tag {
  display: inline-block;
  margin-right: 8rpx;
  padding: 4rpx 12rpx;
  background: #eff6ff;
  color: #3B82F6;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.foot {
  font-size: 22rpx;
  color: #9ca3af;
}

.foot text {
  margin-right: 24rpx;
}

.arrow {
  font-size: 36rpx;
  color: #d1d5db;
}

.empty {
  text-align: center;
  padding: 80rpx;
  font-size: 28rpx;
  color: #9ca3af;
}
