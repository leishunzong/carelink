.page {
  min-height: 100vh;
  padding-bottom: 160rpx;
  background: #f5f5f5;
}

.header-wrap {
  padding: 24rpx;
}

.basic-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
}

.top-row {
  display: flex;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}

.info-col {
  flex: 1;
  min-width: 0;
}

.name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.stars {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.star {
  font-size: 28rpx;
  color: #f5a623;
}

.rating-num {
  font-size: 28rpx;
  color: #666;
}

.meta-row {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.meta-row text {
  margin-right: 8rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tag {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.tag-pos {
  background: #e8f5e9;
  border: 1rpx solid #a5d6a7;
  color: #2e7d32;
}

.tag-neg {
  background: #ffebee;
  border: 1rpx solid #ef9a9a;
  color: #c62828;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #3B82F6;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* Tab */
.tabs {
  display: flex;
  background: #fff;
  margin-top: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  color: #3B82F6;
  font-weight: 600;
  position: relative;
}

.tab.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #3B82F6;
  border-radius: 3rpx;
}

.tab-content {
  background: #fff;
  min-height: 400rpx;
  padding: 32rpx;
}

.content-panel {
  padding: 0;
}

.info-line {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
}

.info-label {
  color: #999;
}

.info-value {
  color: #333;
}

.panel-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.skill-group {
  margin-bottom: 32rpx;
}

.skill-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skill-tag {
  padding: 12rpx 24rpx;
  background: #eff6ff;
  color: #3B82F6;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.review-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.review-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.review-user {
  font-size: 26rpx;
  color: #666;
}

.review-star {
  font-size: 26rpx;
  color: #f5a623;
}

.review-content {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.review-date {
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 48rpx;
  color: #999;
  font-size: 28rpx;
}

/* AI Summary */
.ai-summary-section {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.ai-summary-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.ai-summary-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.ai-summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  background: linear-gradient(90deg, #6366f1, #3b82f6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ai-summary-body {
  background: linear-gradient(135deg, #f0f4ff, #faf5ff);
  border-radius: 16rpx;
  padding: 28rpx;
  border: 1rpx solid #e0e7ff;
}

.ai-summary-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.7;
}

.ai-summary-empty {
  font-size: 26rpx;
  color: #999;
}

.ai-summary-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
}

.ai-loading-dot {
  font-size: 24rpx;
  color: #6366f1;
  margin-right: 12rpx;
  animation: aiPulse 1.2s ease-in-out infinite;
}

.ai-loading-text {
  font-size: 26rpx;
  color: #888;
}

@keyframes aiPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.service-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.service-icon {
  width: 96rpx;
  height: 96rpx;
  background: #eff6ff;
  border-radius: 16rpx;
  text-align: center;
  line-height: 96rpx;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  min-width: 0;
}

.service-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-btn {
  padding: 16rpx 32rpx;
  background: #3B82F6;
  color: #fff;
  font-size: 26rpx;
  border-radius: 40rpx;
  flex-shrink: 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}

.btn-primary.full {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #3B82F6 !important;
  color: #fff !important;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
}
