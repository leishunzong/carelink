.page {
  min-height: 100vh;
  background: #f9fafb;
  display: flex;
  flex-direction: column;
}

/* 城市信息 */
.city-info {
  background: #eff6ff;
  padding: 12rpx 32rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.city-text {
  font-size: 24rpx;
  color: #3b82f6;
}

/* Search */
.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-bar {
  flex: 1;
  height: 72rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
}
.search-input { flex: 1; font-size: 28rpx; height: 72rpx; }
.btn-search {
  background: #3B82F6;
  color: #fff;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

/* Tabs */
.tabs-wrap {
  white-space: nowrap;
  background: #fff;
  border-bottom: 1rpx solid #e5e7eb;
}
.tabs-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
}
.tab {
  display: inline-block;
  padding: 14rpx 32rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 40rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
.tab.active { background: #3B82F6; color: #fff; }

/* Filters */
.filter-wrap {
  white-space: nowrap;
  background: #fff;
  border-bottom: 1rpx solid #e5e7eb;
}
.filter-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
}
.filter-btn {
  display: inline-block;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 40rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
.filter-btn.active { background: #3B82F6; color: #fff; }

/* List */
.list {
  flex: 1;
  padding: 24rpx 32rpx;
  height: 0;
}
.card {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}
.body { flex: 1; margin-left: 24rpx; min-width: 0; }
.head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.name { font-size: 30rpx; font-weight: 600; color: #111827; }
.status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.status-accepting { background: #10b981; color: #fff; }
.status-serving { background: #3B82F6; color: #fff; }
.status-rest { background: #9ca3af; color: #fff; }

.meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}
.star { color: #f59e0b; font-weight: 500; }
.exp { color: #6b7280; }
.info { color: #9ca3af; }

.services { margin-bottom: 12rpx; }
.tag {
  display: inline-block;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  padding: 4rpx 16rpx;
  background: #eff6ff;
  color: #3B82F6;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
}
.price { color: #3B82F6; font-weight: 600; }
.orders { color: #9ca3af; }
.arrow { font-size: 36rpx; color: #d1d5db; margin-left: 8rpx; }

.empty, .loading-tip {
  text-align: center;
  padding: 48rpx;
  font-size: 28rpx;
  color: #9ca3af;
}

/* Picker popup */
.picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}
.picker-popup {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  max-height: 60vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  z-index: 101;
  overflow-y: auto;
}
.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}
.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 16rpx;
  font-size: 30rpx;
  color: #111827;
  border-bottom: 1rpx solid #f3f4f6;
}
.picker-item.selected { color: #3B82F6; }
.check { color: #3B82F6; font-size: 32rpx; }
