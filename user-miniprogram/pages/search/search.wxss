.page { min-height: 100vh; background: #f9fafb; }

.search-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}
.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f3f4f6;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}
.search-icon { font-size: 28rpx; color: #9ca3af; }
.search-input { flex: 1; font-size: 28rpx; }
.cancel { font-size: 28rpx; color: #3B82F6; flex-shrink: 0; }

.section { background: #fff; padding: 32rpx; margin-top: 16rpx; }
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-title { font-size: 30rpx; font-weight: 600; color: #111827; }
.section-clear { font-size: 24rpx; color: #9ca3af; }

.tag-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag {
  padding: 12rpx 28rpx;
  background: #f3f4f6;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #374151;
}
.tag.hot { background: #eff6ff; color: #3B82F6; }
.tag:active { opacity: 0.7; }

.results { padding: 24rpx 32rpx; }
.result-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.result-cover {
  width: 224rpx;
  height: 224rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}
.result-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}
.result-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}
.result-desc {
  font-size: 24rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.result-price-row { margin-top: 16rpx; }
.result-price { font-size: 36rpx; font-weight: 700; color: #3B82F6; }
.result-unit { font-size: 24rpx; color: #6b7280; }

.empty { text-align: center; padding: 80rpx 0; font-size: 28rpx; color: #9ca3af; }
