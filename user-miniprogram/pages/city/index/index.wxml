<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索城市" value="{{searchQuery}}" bindinput="onSearchInput" />
  </view>
  <view class="section">
    <view class="section-title"><image class="loc-icon" src="https://zlisten-1323337406.cos.ap-beijing.myqcloud.com/images/%E5%AE%9A%E4%BD%8D-%E4%BD%8D%E7%BD%AE.png" mode="aspectFit"></image> 当前定位城市</view>
    <view class="city-btn current" bindtap="onUseLocatedCity">
      <text>{{locateLoading ? '定位中…' : (locatedCity || '未定位')}}</text>
    </view>
    <view class="locate-tip">点击上方使用该城市；若显示「定位失败」或「未获取定位」可再次点击重试</view>
  </view>
  <view class="section" wx:if="{{useSearchResults}}">
    <view class="section-title">搜索结果</view>
    <view class="search-loading" wx:if="{{searchLoading}}">搜索中…</view>
    <view class="city-list" wx:else>
      <view class="city-btn" wx:for="{{searchResults}}" wx:key="id" data-city="{{item.fullname}}" data-code="{{item.id}}" bindtap="onSelect">{{item.fullname}}</view>
    </view>
    <view class="empty-tip" wx:if="{{!searchLoading && searchResults.length === 0}}">未找到相关城市</view>
  </view>
  <view class="section" wx:else>
    <view class="section-title">热门城市</view>
    <view class="city-grid">
      <view class="city-btn" wx:for="{{filteredCities}}" wx:key="*this" data-city="{{item}}" bindtap="onHotSelect">{{item}}</view>
    </view>
  </view>
</view>
