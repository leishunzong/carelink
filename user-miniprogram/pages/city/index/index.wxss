.page {
  min-height: 100vh;
  background: #f9fafb;
  padding: 32rpx;
}

.search-bar {
  margin-bottom: 32rpx;
}

.search-input {
  height: 80rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}
.loc-icon {
  width: 28rpx;
  height: 28rpx;
  min-width: 28rpx;
  min-height: 28rpx;
  max-width: 28rpx;
  max-height: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.city-btn {
  padding: 24rpx 32rpx;
  background: #f3f4f6;
  color: #111827;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.city-btn.current {
  background: #eff6ff;
  border: 2rpx solid #93c5fd;
  color: #3B82F6;
  font-weight: 500;
}

.city-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.city-grid .city-btn {
  flex: 0 0 calc(33.33% - 12rpx);
  margin-bottom: 0;
  text-align: center;
}

.locate-tip {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 16rpx;
}

.city-list .city-btn {
  margin-bottom: 16rpx;
}

.city-list .city-btn:last-child {
  margin-bottom: 0;
}

.search-loading,
.empty-tip {
  font-size: 28rpx;
  color: #9ca3af;
  padding: 24rpx 0;
}
