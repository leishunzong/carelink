.page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background: #f9fafb;
}

.order-info {
  background: #fff;
  padding: 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.order-no {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.order-desc {
  font-size: 30rpx;
  color: #111827;
}

.block {
  background: #fff;
  margin-top: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.block-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

.stars {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.star {
  font-size: 64rpx;
  color: #e5e7eb;
}

.star.on {
  color: #f59e0b;
}

.star-tip {
  text-align: center;
  font-size: 26rpx;
  color: #6b7280;
}

.type-row {
  display: flex;
  gap: 24rpx;
}

.type-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #6b7280;
}
.type-icon {
  width: 36rpx;
  height: 36rpx;
  min-width: 36rpx;
  min-height: 36rpx;
  max-width: 36rpx;
  max-height: 36rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.type-btn.active {
  border-color: #10b981;
  background: #ecfdf5;
  color: #059669;
}

.type-btn.negative.active {
  border-color: #ef4444;
  background: #fef2f2;
  color: #dc2626;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 16rpx 28rpx;
  background: #f3f4f6;
  color: #6b7280;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.tag.on {
  background: #3B82F6;
  color: #fff;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.count {
  text-align: right;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 12rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: #374151;
}

.submit-block {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.full {
  width: 100%;
}
