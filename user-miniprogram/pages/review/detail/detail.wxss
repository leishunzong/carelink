.page {
  min-height: 100vh;
  background: #f9fafb;
  padding: 32rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.caregiver {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.type {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.type.positive { background: #d1fae5; color: #059669; }
.type.negative { background: #fee2e2; color: #dc2626; }

.service {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.order-no {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 24rpx;
}

.stars {
  font-size: 28rpx;
  color: #f59e0b;
  margin-bottom: 20rpx;
}

.tags {
  margin-bottom: 20rpx;
}

.tag {
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  padding: 8rpx 20rpx;
  background: #eff6ff;
  color: #3B82F6;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.content {
  font-size: 30rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.time {
  font-size: 24rpx;
  color: #9ca3af;
}

.loading {
  text-align: center;
  padding: 80rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 80rpx;
  color: #9ca3af;
}
