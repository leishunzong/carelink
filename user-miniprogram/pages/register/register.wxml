<view class="page">
  <view class="bg">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
  </view>
  <view class="content">
    <view class="title-wrap">
      <view class="logo">✍️</view>
      <text class="title">注册账号</text>
      <text class="subtitle">加入我们，享受专业护理服务</text>
    </view>
    <view class="form">
      <view class="field">
        <text class="label">账号</text>
        <input class="input" placeholder="请输入账号" value="{{username}}" bindinput="onUsernameInput" />
      </view>
      <view class="field">
        <text class="label">昵称</text>
        <input class="input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" />
      </view>
      <view class="field">
        <text class="label">手机号</text>
        <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
      <view class="field">
        <text class="label">密码</text>
        <input class="input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <view class="field">
        <text class="label">确认密码</text>
        <input class="input" type="password" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmInput" />
      </view>
      <button class="submit-btn" bindtap="onSubmit" loading="{{loading}}">注册</button>
      <view class="footer">
        <text class="link" bindtap="goLogin">已有账号？去登录</text>
      </view>
    </view>
  </view>
</view>
