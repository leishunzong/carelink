.page {
  min-height: 100vh;
  background: #f9fafb;
  padding: 32rpx 32rpx 48rpx;
}

.block {
  background: #fff;
  border-radius: 20rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.row:last-child {
  border-bottom: none;
}

.label {
  width: 180rpx;
  font-size: 28rpx;
  color: #374151;
  flex-shrink: 0;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
  text-align: right;
}

.value.placeholder {
  color: #9ca3af;
}

.arrow {
  margin-left: 16rpx;
  font-size: 32rpx;
  color: #9ca3af;
}

.row-picker .picker-trigger {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 80rpx;
}
.row-picker .value-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.row-picker .value-wrap .value {
  flex: none;
}
.row-picker .value-wrap .arrow {
  flex-shrink: 0;
}

.input {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
  text-align: right;
}

.switch-row {
  justify-content: space-between;
}

.save-btn {
  width: 100%;
  margin-top: 32rpx;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.picker-popup {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  max-height: 50vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  padding: 24rpx;
  overflow-y: auto;
}

.picker-item {
  padding: 28rpx;
  font-size: 30rpx;
  color: #111827;
  border-bottom: 1rpx solid #f3f4f6;
}

.picker-item:last-child {
  border-bottom: none;
}
