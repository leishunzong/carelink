<view class="page">
  <view class="list" wx:if="{{list.length > 0}}">
    <view class="card" wx:for="{{list}}" wx:key="id" bindtap="onCardTap" data-id="{{item.id}}">
      <view class="delete-btn" catchtap="onDelete" data-id="{{item.id}}" wx:if="{{!isSelectMode}}">删除</view>
      <view class="head">
        <text class="name">{{item.name}}</text>
        <text class="tag default" wx:if="{{item.isDefault}}">默认</text>
      </view>
      <text class="meta">{{item.gender === 1 ? '男' : '女'}} · {{item.age != null ? item.age : '-'}}岁</text>
      <view class="row">
        <text>自理能力：{{item.selfCareAbility || item.selfCare || '-'}}</text>
        <text>智力状态：{{item.intellectStatus || '-'}}</text>
      </view>
      <view class="history" wx:if="{{item.medicalHistory}}">
        <text class="history-label">病史</text>
        <text class="history-text">{{item.medicalHistory}}</text>
      </view>
    </view>
  </view>
  <view class="empty" wx:else>
    <text class="empty-icon">👤</text>
    <text class="empty-text">暂无服务对象</text>
    <button class="btn-primary add-btn" bindtap="goAdd">添加服务对象</button>
  </view>
  <view class="bottom-bar" wx:if="{{!isSelectMode && list.length > 0}}">
    <button class="btn-primary full" bindtap="goAdd">+ 添加新服务对象</button>
  </view>
</view>
