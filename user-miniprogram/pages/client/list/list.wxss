.page {
  min-height: 100vh;
  background: #f9fafb;
  padding: 32rpx 32rpx 180rpx;
}

.card {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 32rpx 32rpx 100rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.delete-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 26rpx;
  color: #ef4444;
}

.head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.tag.default {
  background: #3B82F6;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.meta {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.row {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.history {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
}

.history-label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.history-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.5;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 48rpx;
}

.add-btn {
  width: 320rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}

.full {
  width: 100%;
}
