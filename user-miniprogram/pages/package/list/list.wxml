<view class="page">
  <!-- 搜索栏（从搜索入口进入时显示） -->
  <view class="search-bar" wx:if="{{fromSearch}}">
    <input class="search-input" placeholder="搜索服务包" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch" focus="{{fromSearch}}" />
    <text class="search-btn" bindtap="onSearch">搜索</text>
  </view>

  <!-- 分类 Tab -->
  <scroll-view class="tabs-wrap" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tabs-inner">
      <view class="tab {{categoryId === item.id ? 'active' : ''}}" wx:for="{{categoryList}}" wx:key="id" data-id="{{item.id}}" bindtap="onTab">{{item.name}}</view>
    </view>
  </scroll-view>

  <!-- 列表 -->
  <scroll-view class="list" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onReachBottom">
    <view class="card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <image class="cover" src="{{item.image || ''}}" mode="aspectFill" />
      <view class="info">
        <text class="name">{{item.name}}</text>
        <text class="desc">{{item.description}}</text>
        <view class="price-row">
          <text class="price">¥{{item.displayPrice}}</text>
          <text class="unit">/{{item.displayUnit}}起</text>
        </view>
        <view class="foot-row">
          <text class="sales">已售 {{item.sales}}</text>
          <view class="btn-book" catchtap="goBook" data-id="{{item.id}}">预约</view>
        </view>
      </view>
    </view>
    <view class="empty" wx:if="{{!loading && list.length === 0}}">暂无服务</view>
    <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
  </scroll-view>
</view>
