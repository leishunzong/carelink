.page {
  min-height: 100vh;
  background: #f9fafb;
  display: flex;
  flex-direction: column;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
}
.search-input {
  flex: 1;
  height: 64rpx;
  background: #f3f4f6;
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}
.search-btn {
  margin-left: 24rpx;
  font-size: 28rpx;
  color: #3B82F6;
}

.tabs-wrap {
  white-space: nowrap;
  background: #fff;
  border-bottom: 1rpx solid #e5e7eb;
}
.tabs-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
}
.tab {
  display: inline-block;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 40rpx;
  white-space: nowrap;
}
.tab.active {
  background: #3B82F6;
  color: #fff;
}

.list {
  flex: 1;
  padding: 24rpx 32rpx;
  height: 0;
}

.card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.cover {
  width: 256rpx;
  height: 256rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}
.info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}
.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.desc {
  font-size: 24rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-clamp: 2;
}
.price-row { margin-top: 12rpx; }
.price { font-size: 36rpx; font-weight: 700; color: #3B82F6; }
.unit { font-size: 24rpx; color: #6b7280; margin-left: 4rpx; }

.foot-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f4f6;
}
.sales { font-size: 24rpx; color: #9ca3af; }
.btn-book {
  background: #3B82F6;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 28rpx;
  border-radius: 40rpx;
}

.empty, .loading-tip {
  text-align: center;
  padding: 48rpx;
  font-size: 28rpx;
  color: #9ca3af;
}
