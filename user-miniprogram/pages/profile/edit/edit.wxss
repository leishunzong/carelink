.page {
  min-height: 100vh;
  background: #f9fafb;
}

/* 自定义导航栏：与原型一致 */
.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 10;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-back {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.nav-back-icon {
  font-size: 48rpx;
  color: #111827;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #111827;
}

.nav-right {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.nav-save {
  font-size: 28rpx;
  color: #3B82F6;
}

.content {
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 48rpx;
}

.block {
  background: #fff;
  border-radius: 20rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.row-avatar {
  min-height: 120rpx;
  padding: 24rpx 0;
}

.row-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 120rpx;
}

.row-right .arrow {
  margin-left: 16rpx;
}

.row:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #374151;
  flex-shrink: 0;
}

.input {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
  text-align: right;
}

.value, .readonly {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
  text-align: right;
}

.value.placeholder {
  color: #9ca3af;
}

.readonly {
  color: #9ca3af;
}

.row-picker .picker-trigger {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 80rpx;
}

.row-picker .value-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.row-picker .value-wrap .arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.arrow {
  margin-left: 16rpx;
  font-size: 32rpx;
  color: #9ca3af;
}

.avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #e5e7eb;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 48rpx;
}

.tip {
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
  padding: 32rpx 0;
}

.save-btn {
  width: 100%;
  margin-top: 32rpx;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.picker-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.picker-item {
  padding: 28rpx;
  font-size: 30rpx;
  color: #111827;
}
