<view class="page">
  <view class="bg">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
  </view>
  <view class="content">
    <view class="title-wrap">
      <view class="logo">👋</view>
      <text class="title">欢迎回来</text>
      <text class="subtitle">登录您的护联账号</text>
    </view>
    <view class="form">
      <view class="field">
        <text class="label">账号</text>
        <view class="input-box">
          <text class="field-icon">👤</text>
          <input class="input" placeholder="请输入账号" value="{{account}}" bindinput="onAccountInput" />
        </view>
      </view>
      <view class="field">
        <text class="label">密码</text>
        <view class="input-box">
          <text class="field-icon">🔒</text>
          <input class="input" type="text" password="{{!passwordVisible}}" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
          <view class="eye-wrap" bindtap="onTogglePassword">
            <text class="eye-icon">{{passwordVisible ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>
      <view class="forgot-wrap">
        <text class="forgot">忘记密码？</text>
      </view>
      <button class="submit-btn" bindtap="onSubmit" loading="{{loading}}">登录</button>
      <view class="footer">
        <text class="link" bindtap="goRegister">还没有账号？去注册</text>
      </view>
    </view>
  </view>
</view>
